# ---- API + worker shared ----
SUPABASE_URL=https://wijetunpfvklttzpgogn.supabase.co
# service-role key: server-side only, bypasses RLS. NEVER ship to the browser.
SUPABASE_SERVICE_KEY=
# anon/publishable key (optional, not used by the browser here)
SUPABASE_KEY=sb_publishable_xxx

# ---- API ----
PORT=3000
LOCALE=en
CACHE_TTL_MS=600000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
# base URL the worker uses to reach this API
API_BASE=http://localhost:3000

# ---- worker / PEAR ----
PEAR_DIR=D:\PEAR
PEAR_PYTHON=D:\PEAR\.venv\Scripts\python.exe
